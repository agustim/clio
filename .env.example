# Database
DATABASE_URL=sqlite://data/linkanalyzer.db

# Server
BIND_ADDR=127.0.0.1:8080

# LLM (Optional). Si LLM_PROVIDER buit o "none" o no s'arriba a l'endpoint => fallback extractiu.
# vllm/openai/ollama exposen API compatible OpenAI a /v1/chat/completions.
LLM_PROVIDER=vllm
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
# Timeout per crida al LLM (segons). Models grans triguen molt generant; puja si veus
# "error sending request" al deep pass. Per defecte 120.
LLM_TIMEOUT_SECS=120

# Embeddings (independents del LLM de chat). Habiliten el ranking personalitzat
# per "cors" a la web. Backfill dels links existents: `linkanalyzer reindex`.
#
# EMBED_PROVIDER:
#   local   -> in-process via fastembed (cap servei extern; descarrega el model
#              el primer cop i després offline). Requereix feature 'local-embed'.
#   openai  -> API d'OpenAI (EMBED_MODEL=text-embedding-3-small, EMBED_DIM honora dimensions).
#   ollama/vllm/http -> qualsevol endpoint OpenAI-compatible (/embeddings).
#   (buit)  -> reusa LLM_PROVIDER.
#
# EMBED_BASE_URL / EMBED_API_KEY: si es deixen buits, es reusen els de LLM_*.
# En mode local, EMBED_MODEL és l'id de fastembed (p.ex. multilingual-e5-small,
# bge-m3, nomic-embed-text) i EMBED_BASE_URL/DIM s'ignoren.
EMBED_PROVIDER=local
EMBED_MODEL=multilingual-e5-small
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_DIM=256

# Git repo per a la web estàtica (push opt-in: nomes si WEB_REPO_URL definit)
WEB_REPO_URL=
WEB_BRANCH=main
GIT_TOKEN=

# Telegram: el bot accepta links d'usuaris amb telegram_id i respon "Processant url.".
TELEGRAM_BOT_TOKEN=
# Chat on el bot envia avisos d'admin (arrencada + errors d'anàlisi). Buit = cap
# avís. El teu id numèric el dóna @userinfobot; els grups tenen id negatiu.
ADMIN_CHAT_ID=

# Sortida web
PUBLIC_DIR=public

# Limits
MAX_LINK_SIZE_MB=5
SUMMARY_MAX_WORDS=300
SUMMARY_MAX_CHARS=150
# UA de navegador real per defecte; molts murs bloquegen UA de bot.
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# Pàgines protegides (Cloudflare & co.): fallback via FlareSolverr en 403/429/503.
# Buit = desactivat. El docker-compose ja inclou el servei `flaresolverr`.
FLARESOLVERR_URL=http://flaresolverr:8191
FLARESOLVERR_TIMEOUT_SECS=60

# Cua d'anàlisi async
QUEUE_WORKERS=4

# Regeneració periòdica de la web durant `serve` (segons). 0 = desactiva.
# Posa 0 si uses el deploy reactiu (recomanat): la web es regenera i fa push
# només quan s'acaba d'analitzar un link nou.
WEB_REGEN_SECS=0

# Deploy reactiu: finestra (segons) per agrupar una ràfega de links nous en
# un sol push/deploy després que la cua acabi d'analitzar.
WEB_DEBOUNCE_SECS=60

# Segona passada (deep): clone de repos
CLONE_TIMEOUT_SECS=120
CLONE_MAX_MB=200

# Cloudflare Tunnel (docker-compose.yml). Token del tunnel creat a
# Zero Trust > Networks > Tunnels. Public Hostname -> http://clio:8080.
TUNNEL_TOKEN=
